{
  "env": {
    "CLAUDE_BUILD_CHECK_SKIP": "1"
  },
  "permissions": {
    "allow": [
      "Bash(ast-grep scan *)",
      "Bash(curl -sI *)",
      "Bash(curl -fsS -o /dev/null *)",
      "Bash(gh search *)",
      "Bash(git ls-tree *)",
      "Bash(hugo --gc)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "command -v lefthook >/dev/null 2>&1 && lefthook install >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}

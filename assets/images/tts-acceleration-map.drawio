        <mxCell id="q1-title" value="① AR codec LM × 投機的 TTS" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="138" width="440" height="26" as="geometry" />
        </mxCell>
        <mxCell id="q1-models" value="代表モデル&#10;VALL-E / Llasa / CosyVoice 2&#10;Spark-TTS / XTTS v2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#34495e;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">

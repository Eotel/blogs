        </mxCell>
        <mxCell id="svc-shipping" value="&lt;b&gt;Shipping&lt;/b&gt;&lt;br&gt;Service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="715" y="415" width="130" height="48" as="geometry" />
        </mxCell>
        <mxCell id="cmd-order" edge="1" parent="1" source="orchestrator" target="svc-order" value="CreateOrder" style="endArrow=classic;html=1;rounded=0;strokeColor=#ef6c00;fontColor=#ef6c00;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cmd-inventory" edge="1" parent="1" source="orchestrator" target="svc-inventory" value="ReserveStock" style="endArrow=classic;html=1;rounded=0;strokeColor=#ef6c00;fontColor=#ef6c00;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="cmd-payment" edge="1" parent="1" source="orchestrator" target="svc-payment" value="ChargeCard" style="endArrow=classic;html=1;rounded=0;strokeColor=#ef6c00;fontColor=#ef6c00;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />

          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="evt1" value="OrderCreated" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#6a1b9a;fontStyle=2;" vertex="1" parent="1">

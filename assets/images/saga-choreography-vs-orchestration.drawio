          <mxGeometry x="320" y="300" width="160" height="54" as="geometry" />
        </mxCell>
        <mxCell id="broker-left" value="&lt;b&gt;Message Broker&lt;/b&gt;（Kafka / SQS / Rabbit）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#6a1b9a;dashed=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="440" width="420" height="44" as="geometry" />
        </mxCell>
        <mxCell id="choreography-summary" value="利点: 疎結合 / 新規サービス追加が容易&#10;欠点: 全体フローの可視化が難しい・イベント順序問題が起きやすい&#10;失敗時: 補償イベントを各サービスが自律的に発火する" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="50" y="510" width="440" height="72" as="geometry" />
        </mxCell>

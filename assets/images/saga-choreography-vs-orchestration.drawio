        <mxCell id="cmd-shipping" edge="1" parent="1" source="svc-inventory" target="svc-shipping" value="DispatchShipment" style="endArrow=classic;html=1;rounded=0;strokeColor=#ef6c00;fontColor=#ef6c00;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="orchestration-summary" value="利点: 全体フローが 1 箇所に集約・失敗時の補償も中央から指示できる&#10;欠点: オーケストレータが SPOF になりがち・業務ロジックが中央に集中する&#10;失敗時: 逆順に Cancel コマンドを発行して補償する" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="575" y="510" width="410" height="72" as="geometry" />
        </mxCell>
      </root>

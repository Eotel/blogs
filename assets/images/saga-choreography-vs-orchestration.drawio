<mxfile host="app.diagrams.net">
  <diagram id="saga-choreography-vs-orchestration" name="Saga choreography vs orchestration">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="640" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Saga の 2 方式: 注文フローを書き比べる" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="20" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="left-panel" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#b3b3b3;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="500" height="540" as="geometry" />
        </mxCell>
        <mxCell id="left-title" value="Choreography（イベント連鎖）" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=15;fontStyle=1;fontColor=#1565c0;" vertex="1" parent="1">
          <mxGeometry x="110" y="76" width="320" height="26" as="geometry" />
        </mxCell>
        <mxCell id="left-note" value="中央の制御はなく、各サービスがイベントを購読して次の振る舞いを決める" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="95" y="102" width="350" height="34" as="geometry" />
        </mxCell>
        <mxCell id="order-service" value="&lt;b&gt;Order Service&lt;/b&gt;&lt;br&gt;注文を受け付ける" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="60" y="150" width="160" height="54" as="geometry" />
        </mxCell>
        <mxCell id="inventory-service" value="&lt;b&gt;Inventory Service&lt;/b&gt;&lt;br&gt;在庫を引き当てる" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="320" y="150" width="160" height="54" as="geometry" />

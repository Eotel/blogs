        <mxCell id="payment-service" value="&lt;b&gt;Payment Service&lt;/b&gt;&lt;br&gt;決済を実行する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1">

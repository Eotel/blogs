<mxfile host="app.diagrams.net">
  <diagram id="outbox-dataflow" name="Transactional Outbox dataflow">
    <mxGraphModel dx="1422" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1040" pageHeight="540" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Transactional Outbox のデータフロー" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="440" height="30" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="ビジネス更新と outbox 行の INSERT を同一トランザクションに閉じ込めるのが核心" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="230" y="48" width="580" height="24" as="geometry" />
        </mxCell>
        <mxCell id="app" value="&lt;b&gt;Application&lt;/b&gt;&lt;br&gt;注文を受け付ける&lt;br&gt;トランザクション開始" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#2c3e50;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="110" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="tx" value="同一 DB トランザクション" style="rounded=1;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#c62828;strokeWidth=2;dashed=1;fontSize=13;fontStyle=1;fontColor=#c62828;verticalAlign=top;spacingTop=-24;" vertex="1" parent="1">
          <mxGeometry x="270" y="90" width="280" height="220" as="geometry" />
        </mxCell>
        <mxCell id="db" value="&lt;b&gt;PostgreSQL&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e3f2fd;strokeColor=#1565c0;fontSize=13;verticalAlign=top;spacingTop=12;" vertex="1" parent="1">
          <mxGeometry x="285" y="110" width="250" height="190" as="geometry" />
        </mxCell>
        <mxCell id="orders" value="&lt;b&gt;orders&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;id, user_id,&lt;br&gt;total, status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565c0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="305" y="152" width="100" height="64" as="geometry" />
        </mxCell>
        <mxCell id="outbox" value="&lt;b&gt;outbox&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size: 11px;&quot;&gt;event_id,&lt;br&gt;event_type,&lt;br&gt;payload&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffde7;strokeColor=#f9a825;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="420" y="152" width="100" height="76" as="geometry" />
        </mxCell>
        <mxCell id="sqls" value="INSERT INTO orders ...&#10;INSERT INTO outbox ...&#10;COMMIT" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="310" y="235" width="200" height="54" as="geometry" />
        </mxCell>
        <mxCell id="relay" value="&lt;b&gt;Relay Worker&lt;/b&gt;&lt;br&gt;SELECT ... FOR UPDATE&lt;br&gt;SKIP LOCKED で取得" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e0;strokeColor=#ef6c00;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="110" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="broker" value="&lt;b&gt;Message Broker&lt;/b&gt;&lt;br&gt;Kafka / SQS / RabbitMQ&lt;br&gt;event_id をヘッダ配送" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f3e5f5;strokeColor=#6a1b9a;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="110" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="consumer" value="&lt;b&gt;Consumer&lt;/b&gt;&lt;br&gt;受信した event_id を&lt;br&gt;inbox テーブルで重複検査" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f5e9;strokeColor=#2e7d32;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="370" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="inbox" value="&lt;b&gt;inbox (consumer 側)&lt;/b&gt;&lt;br&gt;event_id PRIMARY KEY&lt;br&gt;UNIQUE 制約で冪等化" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1565c0;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="820" y="375" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="&lt;b&gt;処理ステップ&lt;/b&gt;&#10;1. アプリは orders の更新と outbox への INSERT を同一トランザクションで実行&#10;2. COMMIT 完了。outbox 行と event_id が永続化されたことが保証される&#10;3. Relay Worker が未送信行をロックして broker に publish&#10;4. 成功時 published_at をセット（at-least-once が前提）&#10;5. Consumer は inbox の UNIQUE 制約で重複イベントを排除する" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fafafa;strokeColor=#b3b3b3;align=left;verticalAlign=top;spacing=14;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="540" height="140" as="geometry" />
        </mxCell>
        <mxCell id="a1" edge="1" parent="1" source="app" target="db" value="1" style="endArrow=classic;html=1;rounded=0;strokeColor=#555555;fontColor=#c62828;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a2" edge="1" parent="1" source="db" target="relay" value="2" style="endArrow=classic;html=1;rounded=0;strokeColor=#555555;fontColor=#c62828;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a3" edge="1" parent="1" source="relay" target="broker" value="3" style="endArrow=classic;html=1;rounded=0;strokeColor=#555555;fontColor=#c62828;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="a4" edge="1" parent="1" source="broker" target="consumer" value="4" style="endArrow=classic;html=1;rounded=0;strokeColor=#555555;fontColor=#c62828;fontStyle=1;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="910" y="275" />
              <mxPoint x="690" y="275" />
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="a5" edge="1" parent="1" source="consumer" target="inbox" value="5" style="endArrow=classic;html=1;rounded=0;strokeColor=#555555;fontColor=#c62828;fontStyle=1;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="published" edge="1" parent="1" source="relay" target="outbox" value="published_at 更新" style="endArrow=classic;html=1;rounded=0;strokeColor=#ef6c00;dashed=1;fontColor=#ef6c00;fontSize=10;">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
